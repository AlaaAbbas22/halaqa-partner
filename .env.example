# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; app default is gemini-2.5-flash if unset
# GEMINI_MODEL=gemini-2.5-flash

# Quran.com / Quran Foundation API (used by @quranjs/api server client)
# Register an app and create credentials from the Quran API portal.
QURAN_CLIENT_ID=
QURAN_CLIENT_SECRET=
# Production token host (default matches Quran Foundation live OAuth)
QURAN_OAUTH2_BASE_URL=https://oauth2.quran.foundation

# Default tafsir resource IDs (comma-separated) if the client sends none. Example: Ibn Kathir English is often 171 — confirm via GET /api/tafsirs.
TAFSIR_RESOURCE_IDS=171
